            Callback = function(Value)
                FOVRadiusGlobal = Value
                SaveMasterConfig(CurrentOrbitSpeed, CurrentOrbitRadius, CurrentM1Frequency, CurrentInfiniteWindow, FOVRadiusGlobal, ShowFOVGlobal)
            end
        })

        LeftGroupBox:AddDivider()

        LeftGroupBox:AddToggle('AutoM1ToggleIndex', {
            Text = 'Auto M1 Combat Spam',
