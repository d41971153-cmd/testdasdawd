    local function AttachToPlayer()
        if IsMaster then return end 
        StopAllActions()
        
        AttachConnection = RunService.RenderStepped:Connect(function()
            local targetName = CurrentTargetGlobal
            local target = Players:FindFirstChild(targetName)
            if not target then return end
            
            if target.Character and target.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local targetHRP = target.Character.HumanoidRootPart
                LocalPlayer.Character.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3.5)
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetHRP.Position)
                
                if AutoM1ActiveGlobal and LocalPlayer.Character:FindFirstChild("Humanoid") then
                    LocalPlayer.Character.Humanoid.Jump = true
                end
            end
        end)
    end

    local function TweenToPlayer()
        if IsMaster then return end 
        StopAllActions()
        
        local currentActiveTween = nil
        local activeTweenTargetName = ""

        AttachConnection = RunService.RenderStepped:Connect(function()
            local targetName = CurrentTargetGlobal
            local target = Players:FindFirstChild(targetName)
            if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

            local hrp = LocalPlayer.Character.HumanoidRootPart
            
            if activeTweenTargetName ~= targetName then
                if currentActiveTween then currentActiveTween:Cancel() end
                activeTweenTargetName = targetName
                
                local distance = (hrp.Position - target.Character.HumanoidRootPart.Position).Magnitude
                currentActiveTween = TweenService:Create(hrp, TweenInfo.new(distance / 60, Enum.EasingStyle.Linear), {CFrame = target.Character.HumanoidRootPart.CFrame})
                currentActiveTween:Play()
            end

            if AutoM1ActiveGlobal and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.Jump = true
            end
        end)
    end

    local function StartOrbitEngine(speedValue, radiusValue)
