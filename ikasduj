        local function SaveWaypointsProfile(name)
            if not name then name = '' end
            name = tostring(name):gsub('^%s+', ''):gsub('%s+$','')
            if name == '' then Library:Notify('[Fun] Enter a valid waypoint profile name', 2); return end
            -- sanitize filename
            local safeName = name:gsub('[^%w%-%_]', '_')
            local serial = { Waypoints = {} }
            for _, v in ipairs(Waypoints) do table.insert(serial.Waypoints, {x = v.X, y = v.Y, z = v.Z}) end
            local ok = false
            local ok, err = pcall(function() writefile('aba_waypoints_'..safeName..'.json', HttpService:JSONEncode(serial)) end)
            if not ok then Library:Notify('[Fun] Failed to write waypoint file: '..tostring(err), 4); return end
            -- update index
            local ok2, err2 = pcall(function()
                local idx = {}
                local okr, raw = pcall(function() return readfile('aba_waypoints_index.json') end)
                if okr and raw then
                    local parsed = HttpService:JSONDecode(raw)
                    if type(parsed) == 'table' then idx = parsed end
                end
                if not table.find(idx, safeName) then table.insert(idx, safeName) end
                writefile('aba_waypoints_index.json', HttpService:JSONEncode(idx))
            end)
            if not ok2 then Library:Notify('[Fun] Failed to update waypoint index: '..tostring(err2), 4) end
            local dd = Library.Options and Library.Options.WaypointProfilesDropdown
            if dd then dd:SetValues(GetWaypointProfiles()) end
            Library:Notify('[Fun] Waypoints saved: ' .. name, 2)
        end

