        local function SetTargetToClosestToCursor()
            local mousePos = UserInputService:GetMouseLocation()
            local closestPlayer = nil
            local shortestDistance = FOVRadiusGlobal 
            
            for _, player in pairs(Players:GetPlayers()) do
                local allow = true
                if not SussyOverdriveActiveGlobal then
                    if player == LocalPlayer or Whitelist[player.Name:lower()] then
                        allow = false
                    end
                end
                if not allow or IsPlayerAnActiveBot(player.Name) then
                    -- skip
                else
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = player.Character.HumanoidRootPart
                        local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                        
                        if onScreen then
                            local playerScreenPos = Vector2.new(screenPos.X, screenPos.Y)
                            local dist = (mousePos - playerScreenPos).Magnitude
                            
                            if dist < shortestDistance then
                                shortestDistance = dist
                                closestPlayer = player
                            end
                        end
                    end
                end
            end
            
            if closestPlayer then
                SelectedPlayer = closestPlayer.Name
                
                local activeMode = "STOP"
                if Toggles.Attach and Toggles.Attach.Value then activeMode = "ATTACH"
                elseif Toggles.Tween and Toggles.Tween.Value then activeMode = "TWEEN"
                elseif Toggles.Orbit and Toggles.Orbit.Value then activeMode = "ORBIT"
                end

                local data = GetClusterData()
                data.Target = closestPlayer.Name
                data.Command = activeMode 
                SaveClusterData(data)
                
                pcall(function()
                    PlayerDropdown:SetValue(closestPlayer.Name)
                end)
                
                Library:Notify("[Cluster Master]: Target locked via Z: " .. closestPlayer.Name, 1.5)
            end
        end

