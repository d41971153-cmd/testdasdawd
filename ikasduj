        -- Load waypoint profile file into local Vector3 list
        local function LoadLocalWaypoints(profileName)
            if not profileName or profileName == '' then return {} end
            local ok, raw = pcall(function() return readfile('aba_waypoints_'..tostring(profileName)..'.json') end)
            if not ok or not raw then return {} end
            local ok2, parsed = pcall(function() return HttpService:JSONDecode(raw) end)
            if not ok2 or not parsed or type(parsed.Waypoints) ~= 'table' then return {} end
            local out = {}
            for _, v in ipairs(parsed.Waypoints) do
                if type(v) == 'table' and v.x and v.y and v.z then
