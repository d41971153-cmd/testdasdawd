            -- helper to disable collisions and enable flight-like control
            local function enableFlightNoClip(enable)
                if not LocalPlayer.Character then return end
                local humanoid = LocalPlayer.Character:FindFirstChildOfClass('Humanoid')
                for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA('BasePart') then
                        pcall(function() part.CanCollide = not enable end)
                    end
                end
                if humanoid then
                    pcall(function() humanoid.PlatformStand = enable end)
                end
            end

            -- main waypoint runner using BodyVelocity for ESC-style flight
            task.spawn(function()
                while WaypointActive and Running do
                    local dest = WaypointsListLocal[idx]
                    if not dest then break end
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart') then
                        local hrp = LocalPlayer.Character.HumanoidRootPart
                        -- enable noclip/flight state for smooth motion
                        enableFlightNoClip(true)

                        -- create or reuse BodyVelocity
                        local bv = hrp:FindFirstChild('DWFlightBV')
                        if not bv then
                            bv = Instance.new('BodyVelocity')
                            bv.Name = 'DWFlightBV'
                            bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                            bv.P = 1250
                            bv.Parent = hrp
                        end

                        local arrived = false
                        local timer = 0
                        while WaypointActive and Running and hrp and hrp.Parent and not arrived and timer < 60 do
                            local curPos = hrp.Position
                            local toDest = dest - curPos
                            local dist = toDest.Magnitude
                            if dist <= 1.0 then arrived = true; break end
                            local desired = toDest.Unit * math.min(moveSpeed, dist * 1.2)
                            -- gentle vertical damping to reduce twitch
                            desired = Vector3.new(desired.X, toDest.Y * 0.7, desired.Z)
                            -- smooth velocity lerp
                            local currentV = bv.Velocity or Vector3.new(0,0,0)
                            local newV = currentV:Lerp(desired, 0.25)
                            pcall(function() bv.Velocity = newV end)
                            task.wait(0.04)
                            timer = timer + 0.04
                        end

                        -- cleanup BV at arrival
                        pcall(function()
                            if bv and bv.Parent then bv:Destroy() end
                        end)

                        -- small pause at waypoint
                        task.wait(WaypointPauseValue)
                    else
                        task.wait(0.2)
                    end

                    idx = idx + 1
                    if idx > #WaypointsListLocal then idx = 1 end
                end
                enableFlightNoClip(false)
                WaypointActive = false
            end)
