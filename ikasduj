                end
            end
            return out
        end

        local function StartWaypointsEngine(profileName)
            if IsMaster then return end
            WaypointsListLocal = LoadLocalWaypoints(profileName)
            if #WaypointsListLocal == 0 then return end
            StopAllActions()
            WaypointActive = true
            local idx = 1
            local moveSpeed = WaypointSpeedValue -- studs/s used to compute tween time
