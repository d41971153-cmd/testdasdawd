-- Alt rendering blackout removed (setAltVisibility and AltPartStateStore deleted)

local function clearBlacklistState(preserveWhitelist)
    local preserve = preserveWhitelist ~= false
    local blacklistTerms = {"blacklist", "ignore", "ignored", "blocked", "targetblock"}
    local containers = {ReplicatedStorage, Workspace, LocalPlayer, LocalPlayer:FindFirstChild("PlayerGui")}

    local function nameContainsWhitelist(text)
        if not text then return false end
        local lower = string.lower(tostring(text))
        for w, _ in pairs(Whitelist) do
            if lower:find(w, 1, true) then
                return true
            end
        end
        return false
    end

    for _, container in ipairs(containers) do
        if container then
            for _, obj in ipairs(container:GetDescendants()) do
                local name = string.lower(obj.Name or "")
                local shouldRemove = false
                for _, term in ipairs(blacklistTerms) do
                    if string.find(name, term, 1, true) then
                        shouldRemove = true
                        break
                    end
                end

                if shouldRemove and preserve then
                    -- preserve any blacklist artifacts that reference or protect whitelisted masters
                    if nameContainsWhitelist(obj.Name) then
                        shouldRemove = false
                    else
                        local ok, val = pcall(function() return obj.Value end)
                        if ok and type(val) == "string" and nameContainsWhitelist(val) then
                            shouldRemove = false
                        end
                    end
                end

                if shouldRemove and (obj:IsA("Folder") or obj:IsA("StringValue") or obj:IsA("IntValue") or obj:IsA("BoolValue") or obj:IsA("ObjectValue")) then
                    pcall(function()
                        obj:Destroy()
                    end)
                end
            end
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local blacklistFolder = player:FindFirstChild("Blacklist") or player:FindFirstChild("blacklist")
                if blacklistFolder then
                local shouldDestroy = true
                for _, child in ipairs(blacklistFolder:GetDescendants()) do
                    if preserve and nameContainsWhitelist(child.Name) then
                        shouldDestroy = false
                        break
                    end
                    if child:IsA("StringValue") then
                        local ok, v = pcall(function() return child.Value end)
                        if ok and type(v) == "string" and preserve and nameContainsWhitelist(v) then
                            shouldDestroy = false
                            break
                        end
                    end
                end
                if shouldDestroy then
                    pcall(function()
                        blacklistFolder:Destroy()
                    end)
                end
            end
        end
    end
end

-- Check logic to determine if a specific profile matches criteria
local function IsPlayerStaffProfile(player)
    if player == LocalPlayer or Whitelist[player.Name:lower()] then return false end
    
    -- 1. Check Custom Username List
    if CustomModList[player.Name:lower()] then
        return true
    end
    
    -- 2. Check Official Game Group Rank
    local groupMatch = false
    if GroupCheckEnabled and GroupIdCheckValue and GroupIdCheckValue > 0 then
        pcall(function()
            local rank = player:GetRankInGroup(GroupIdCheckValue)
            if rank >= MinRankCheckValue then
                groupMatch = true
            end
        end)
    end
    
    return groupMatch
end

-- --- CORE MOD DETECTOR HANDLER ---
local function CheckPlayerForStaff(player)
    if not ModDetectorEnabled or not Running then return end
    if player == LocalPlayer or Whitelist[player.Name:lower()] then return end
    
    local isMod = IsPlayerStaffProfile(player)
    
    -- Trigger Protective Action if flagged
    if isMod and not ActiveStaffInServer[player.Name] then
        ActiveStaffInServer[player.Name] = true
        
        -- Fire local alert join sound immediately
        PlayLocalWarningNoise(JoinSoundID)

        if DetectorAction == "Kick" then
            LocalPlayer:Kick("[STAFF DETECTED]: " .. player.Name .. " has entered your game session.")
        elseif DetectorAction == "Server Hop" then
            pcall(function()
                local x = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
                for _, server in pairs(x.data) do
                    if server.playing < server.maxPlayers and server.id ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                        break
                    end
                end
            end)
            task.wait(2)
            LocalPlayer:Kick("[STAFF HOPPING]: Attempting to jump server lobbies...")
        elseif DetectorAction == "Alert Only" then
            pcall(function()
                local Library = loadstring(game:HttpGet('https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/Library.lua'))()
                Library:Notify("[🔴 STAFF JOINED]: Username " .. player.Name .. " has entered the session!", 10)
            end)
