        if charactersFolder then
            for _, page in pairs(charactersFolder:GetChildren()) do
                for _, series in pairs(page:GetChildren()) do
                    local slotsFolder = series:FindFirstChild("Slots")
                    if slotsFolder then
                        for _, slot in pairs(slotsFolder:GetChildren()) do
                            if not table.find(characterList, slot.Name) then
                                table.insert(characterList, slot.Name)
