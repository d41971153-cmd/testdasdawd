-- --- SAFE FILE UTILITIES ---
local function GetClusterData()
    local success, content = pcall(function() return readfile(SharedFileName) end)
    if success and content and content ~= "" then
        local ok, data = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and data then return data end
    end
    return { Command = "STOP", Target = "", OrbitSpeed = 22, OrbitRadius = 6, AutoM1 = false, InfiniteCombo = false, M1Frequency = 0.22, InfiniteWindow = 1.4, Moves = {false, false, false, false}, ChatSpam = false, ActiveBots = {} }
end

local function SaveClusterData(data)
    pcall(function()
        writefile(SharedFileName, HttpService:JSONEncode(data))
    end)
end

-- --- MASTER SAVED SETTINGS UTILITIES ---
local function LoadMasterConfig()
    local success, content = pcall(function() return readfile(MasterConfigFileName) end)
    if success and content and content ~= "" then
        local ok, data = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and data then 
            return data 
        end
    end
    return { SavedSpeed = 22, SavedRadius = 6, SavedFreq = 0.22, SavedWindow = 1.4, SavedFOV = 150, SavedShowFOV = true }
end

local function SaveMasterConfig(speed, radius, freq, win, fov, showFov)
    pcall(function()
        local configData = { SavedSpeed = speed, SavedRadius = radius, SavedFreq = freq, SavedWindow = win, SavedFOV = fov, SavedShowFOV = showFov }
        writefile(MasterConfigFileName, HttpService:JSONEncode(configData))
    end)
end

