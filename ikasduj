                local spreadAngle = angle + ((BotIndexGlobal - 1) * (math.pi * 2 / TotalBotsGlobal))
                
                local targetHRP = target.Character.HumanoidRootPart
                local radius = radiusValue or 6
                
                local offset = Vector3.new(math.sin(spreadAngle) * radius, 0, math.cos(spreadAngle) * radius)
                local calculatedPosition = targetHRP.Position + offset
                
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(calculatedPosition, targetHRP.Position)
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetHRP.Position)
            end
        end)
