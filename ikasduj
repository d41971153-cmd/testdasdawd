local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local TextChatService = game:GetService("TextChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local spinConnection = nil
local chatTask = nil

-- Configuration Variables
local SPIN_SPEED = 50 
local CHAT_COOLDOWN = 0.5 
local BASE_MESSAGE = "i like cheating on roblox because im weird"

-- Create the ScreenGui container
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ToggleMaxSpamWithBypass"
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 999999
screenGui.Enabled = false
screenGui.Parent = CoreGui

-- Create the black frame
local blackFrame = Instance.new("Frame")
blackFrame.Size = UDim2.new(1, 0, 1, 0)
blackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
blackFrame.BorderSizePixel = 0
blackFrame.Active = true
blackFrame.Parent = screenGui

-- Generates a unique numeric identifier to append to messages
local function appendRandomNumber(message)
    local uniqueID = math.random(100000, 999999)
    return string.format("%s [%d]", message, uniqueID)
end

-- Function to safely send chat messages using standard Roblox Chat APIs
local function sendChatMessage(message)
    local formattedMessage = appendRandomNumber(message)
    
    if TextChatService and TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral") then
        TextChatService.TextChannels.RBXGeneral:SendAsync(formattedMessage)
    else
        local sayMessageEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if sayMessageEvent and sayMessageEvent:IsA("RemoteEvent") then
            sayMessageEvent:FireServer(formattedMessage, "All")
        end
    end
end

-- Function to handle loop mechanics
local function toggleSystems(isEnabled)
    if isEnabled then
        -- Start Spinning
        if spinConnection then spinConnection:Disconnect() end
        spinConnection = RunService.RenderStepped:Connect(function()
            local character = localPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(SPIN_SPEED), 0)
            end
        end)
        
        -- Start Chat Spam Loop
        if chatTask then task.cancel(chatTask) end
        chatTask = task.spawn(function()
            while true do
                sendChatMessage(BASE_MESSAGE)
                task.wait(CHAT_COOLDOWN)
            end
        end)
    else
        -- Stop Spinning
        if spinConnection then
            spinConnection:Disconnect()
            spinConnection = nil
        end
        -- Stop Chat Spam Loop
        if chatTask then
            task.cancel(chatTask)
            chatTask = nil
        end
    end
end

-- Toggle handler using the L key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.L then
        screenGui.Enabled = not screenGui.Enabled
        toggleSystems(screenGui.Enabled)
    end
end)
